<?xml version="1.0" ?>
<robot name= "spear_arm">

    <!-- Base link -->
    <link name="base_link">
        <visual>
            <origin xyz="0.025 0 0" rpy="0 0 1.5708"/>
            <geometry>
            <mesh filename="package://arm_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black">
                <color rgba="0.05 0.05 0.05 1.0"/>
            </material>
        </visual>
    </link>

    <!-- Prismatic joint — Stepper Motor (linear axis) -->
    <joint name="linear_joint" type="prismatic">
        <origin xyz = "0 0.03 0.028" rpy = "0 0 0"/>
        <parent link="base_link"/>
        <child link="slider_link"/>
        <axis xyz="0 1 0"/>
        <limit lower="0.0" upper="0.26" effort="100" velocity="0.1"/>
    </joint>

    <link name="slider_link">
        <visual>
            <origin xyz="0.025 -0.03 -0.03" rpy="0 0 1.5708"/>
            <geometry>
            <mesh filename="package://arm_description/meshes/servo_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="base_grey">
            <color rgba="0.5 0.5 0.5 1.0"/>
            </material>
        </visual>
    </link>

    <!-- Revolute joint — Servo Motor -->
    <joint name="servo_joint" type="revolute">
        <origin xyz = "0 0.034 0.08" rpy = "0 0 0"/>
        <parent link="slider_link"/>
        <child link="arm_link"/>
        <axis xyz="0 1 0"/>
        <limit lower="0" upper="1.57" effort="50" velocity="1.0"/>
    </joint>

    <link name="arm_link">
        <visual>
            <origin xyz="0.025 -0.065 -0.1095" rpy="0 0 1.5708"/>
            <geometry>
            <mesh filename="package://arm_description/meshes/spear_head_v1_1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black">
                <color rgba="0.05 0.05 0.05 1.0"/>
            </material>
        </visual>
    </link>

    <!-- ZED camera mount -->
    <link name="zed_camera_link" />

    <joint name="base_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="zed_camera_link"/>
    <origin xyz="-0.15 0.15 0.18" rpy="0 0 0" />
    </joint>
    
    <!-- Camera Center -->
    <link name="zed_camera_center">
        <visual>
        <origin xyz="-0.01 0 0" rpy="0 0 0"/>
        <geometry>
            <mesh filename="package://field_description/meshes/track_meshes/zed2i.stl"/>
        </geometry>
        <material name="black">
            <color rgba="0.05 0.05 0.05 1.0"/>
        </material>
        </visual>
    </link>

    <joint name="zed_camera_center_joint" type="fixed">
    <parent link="zed_camera_link"/>
    <child link="zed_camera_center"/>
    <origin xyz="0 0 0.015" rpy="0 0 0" />
    </joint>


    <!-- Left Camera -->
    <link name="zed_left_camera_frame">
    </link>

    <joint name="zed_left_camera_joint" type="fixed">
    <parent link="zed_camera_center"/>
    <child link="zed_left_camera_frame"/>
    <origin xyz="-0.01 0.06 0" rpy="0 0 0" />
    </joint>

    <link name="zed_left_camera_frame_optical"/>
    <joint name="zed_left_camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    <parent link="zed_left_camera_frame"/>
    <child link="zed_left_camera_frame_optical"/>
    </joint>

    <!-- Right Camera -->
    <link name="zed_right_camera_frame">
    </link>

    <joint name="zed_right_camera_joint" type="fixed">
    <parent link="zed_camera_center"/>
    <child link="zed_right_camera_frame"/>
    <origin xyz="-0.01 -0.06 0" rpy="0 0 0" />
    </joint>

    <link name="zed_right_camera_frame_optical"/>
    <joint name="zed_right_camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0.0 -1.5708"/>
    <parent link="zed_right_camera_frame"/>
    <child link="zed_right_camera_frame_optical"/>
    </joint>

</robot>