          </geometry>
          <material>
            <pbr>
              <metal>
                <albedo>0.93 0.64 0.59 1</albedo>   <!-- RGB 236-162-151 -->
                <roughness>0.8</roughness>           <!-- matte plywood look -->
                <metalness>0.2</metalness>
              </metal>
            </pbr>
            <ambient>0.85 0.55 0.50 1</ambient>
            <diffuse>0.93 0.64 0.59 1</diffuse>
            <specular>0.3 0.3 0.3 1</specular>
