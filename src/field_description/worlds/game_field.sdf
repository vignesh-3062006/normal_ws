<?xml version="1.0"?>
<sdf version='1.9'>
  <world name = "robocon_arena">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin
      filename="libignition-gazebo-physics-system.so"
      name="ignition::gazebo::systems::Physics">
    </plugin>
    <plugin
        filename="gz-sim-user-commands-system"
        name="gz::sim::systems::UserCommands">
    </plugin>
    <plugin
        filename="gz-sim-scene-broadcaster-system"
        name="gz::sim::systems::SceneBroadcaster">
    </plugin>

    <plugin 
        filename="libignition-gazebo-imu-system.so"
        name="ignition::gazebo::systems::Imu">
    </plugin>

    <plugin
        filename="libignition-gazebo-sensors-system.so"
        name="ignition::gazebo::systems::Sensors">
        <render_engine>ogre2</render_engine>
    </plugin>

    <light type="directional" name="sun">
        <cast_shadows>false</cast_shadows>
        <pose>0 0 10 0 0 0</pose>
        <diffuse>0.8 0.8 0.8 1</diffuse>
        <specular>0.2 0.2 0.2 1</specular>
        <attenuation>
            <range>1000</range>
            <constant>0.9</constant>
            <linear>0.01</linear>
            <quadratic>0.001</quadratic>
        </attenuation>
        <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
          <collision name="collision">
          <geometry>
              <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
              </plane>
          </geometry>
          </collision>
          <visual name="visual">
          <geometry>
              <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
              </plane>
          </geometry>
          <material>
              <ambient>1 1 1 1</ambient>
              <diffuse>1 1 1 1</diffuse>
          </material>
          </visual>
      </link>
    </model>

    <model name = 'game_field'>
      <pose relative_to='world'>0 0 0.025 0 0 0</pose>
      <!-- base_link -->
      <link name='base_link'>
        <inertial>
          <mass>57703.387499999997</mass>
          <inertia>
            <ixx>704041.43519500003</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>709871.88164100004</iyy>
            <iyz>0</iyz>
            <izz>1413889.273758</izz>
          </inertia>
        </inertial>
        <collision name='base_link_collision'>
          <geometry>
            <box>
              <size>12.150 12.100 0.05</size>
            </box>
          </geometry>
        </collision>
        <visual name='base_link_visual'>
          <geometry>
            <box>
              <size>12.150 12.100 0.05</size>
            </box>
          </geometry>
          <material>
            <pbr>
              <metal>
                <albedo>0.5 0.5 0.5 1</albedo>        <!-- mid-grey -->
                <roughness>0.7</roughness>             <!-- matte surface -->
                <metalness>0.4</metalness>
              </metal>
            </pbr>
            <ambient>0.4 0.4 0.4 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <specular>0.6 0.6 0.6 1</specular>
            <emissive>0 0 0 1</emissive>
          </material>
        </visual>
      </link>

      <!-- martial club base frames-->
      <link name = "martial_club_base">
        <pose relative_to='base_link'>0 0 0.025 0 0 0</pose>
        <visual name = 'martial_club_visual'>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://field_description/meshes/arena/martial_club_base_1_1.stl</uri>
            </mesh>
          </geometry>
          <material>
            <pbr>
              <metal>
                <albedo>1.0 0.8 0.6 1</albedo>        <!-- light peach -->
                <roughness>0.7</roughness>             <!-- matte look -->
                <metalness>0.2</metalness>             <!-- low metal shine -->
              </metal>
            </pbr>
            <ambient>0.9 0.7 0.5 1</ambient>
            <diffuse>1.0 0.8 0.6 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
            <emissive>0 0 0 1</emissive>
          </material>
        </visual>
        <collision name = 'martial_club_collision'>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://field_description/meshes/arena/martial_club_base_1_1.stl</uri>
            </mesh>
          </geometry>
        </collision>
      </link>

      <joint name='martial_joint' type='fixed'>
          <parent>base_link</parent>
          <child>martial_club_base</child>
      </joint>

      <!-- meihua forest base frames-->
      <link name = "meihua_forest_base_1">
        <pose relative_to='base_link'>0 0 0.0255 0 0 0</pose>
        <visual name = 'meihua_forest_1_visual'>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://field_description/meshes/arena/meihua_forest_1_1_1.stl</uri>
