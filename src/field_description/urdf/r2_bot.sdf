<?xml version="1.0" ?>
<sdf version='1.9'>
<world name="zyrabot_world">
    <!-- define the gazebo world-->
    <physics name="1ms" type="ignored">
        <max_step_size>0.001</max_step_size>
        <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin
        filename="gz-sim-physics-system"
        name="gz::sim::systems::Physics">
    </plugin>
    <plugin
        filename="gz-sim-user-commands-system"
        name="gz::sim::systems::UserCommands">
    </plugin>
    <plugin
        filename="gz-sim-scene-broadcaster-system"
        name="gz::sim::systems::SceneBroadcaster">
    </plugin>

    <light type="directional" name="sun">
        <cast_shadows>false</cast_shadows>
        <pose>0 0 10 0 0 0</pose>
        <diffuse>0.8 0.8 0.8 1</diffuse>
        <specular>0.2 0.2 0.2 1</specular>
        <attenuation>
            <range>1000</range>
            <constant>0.9</constant>
            <linear>0.01</linear>
            <quadratic>0.001</quadratic>
        </attenuation>
        <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
          <static>true</static>
          <link name="link">
              <collision name="collision">
              <geometry>
                  <plane>
                  <normal>0 0 1</normal>
                  <size>20 20</size>
                  </plane>
              </geometry>
              </collision>
              <visual name="visual">
              <geometry>
                  <plane>
                  <normal>0 0 1</normal>
                  <size>20 20</size>
                  </plane>
              </geometry>
              <material>
                  <ambient>1 1 1 1</ambient>
                  <diffuse>1 1 1 1</diffuse>
              </material>
              </visual>
          </link>
        </model>

    <model name="r2_bot" canonical_link="base_link">
      <pose relative_to='world'>6.45 1.4 0.395 1.5708 0 0</pose>

      <plugin name="gz::sim::systems::DiffDrive" filename="gz-sim-diff-drive-system">
        <left_joint>left_wheel_joint_1</left_joint>
        <right_joint>right_wheel_joint_1</right_joint>
        <left_joint>left_wheel_joint_2</left_joint>
        <right_joint>right_wheel_joint_2</right_joint>

        <!-- Topics -->
        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>

        <!-- Coordinate frames -->
        <odom_frame>odom</odom_frame>
        <robot_base_frame>chassis</robot_base_frame>

        <!-- Physical params -->
        <wheel_separation>1.0</wheel_separation>
        <wheel_radius>0.4</wheel_radius>

        <!-- Limits -->
        <max_linear_acceleration>2.0</max_linear_acceleration>
        <max_angular_acceleration>3.0</max_angular_acceleration>

        <!-- Odometry settings -->
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
      </plugin>

      <plugin
        filename="ignition-gazebo-joint-state-publisher-system"
        name="ignition::gazebo::systems::JointStatePublisher">
        <topic>/joint_staets</topic>
        <joint_name>left_wheel_joint_1</joint_name>
        <joint_name>left_wheel_joint_2</joint_name>
        <joint_name>right_wheel_joint_1</joint_name>
        <joint_name>right_wheel_joint_2</joint_name>
      </plugin>

          
      <link name='base_link'>
        <inertial>
          <pose>-0.001304999475102784 -0.3200000000000006 -0.3481647983110309 0 0 0</pose>
          <mass>14.83418192183056</mass>
          <inertia>
            <ixx>0.89943799999999996</ixx>
            <ixy>0</ixy>
            <ixz>-0.0024989999999999999</ixz>
            <iyy>2.0993010000000001</iyy>
            <iyz>0</iyz>
            <izz>1.202064</izz>
          </inertia>
        </inertial>
        <collision name='base_link_collision'>
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://r2_description/meshes/r2_chassis/base_link.stl</uri>
            </mesh>
          </geometry>
          <surface>
            <contact>
              <ode/>
            </contact>
            <friction>
              <ode>
                <mu>0.20000000000000001</mu>
                <mu2>0.20000000000000001</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name='base_link_visual'>
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://r2_description/meshes/r2_chassis/base_link.stl</uri>
            </mesh>
          </geometry>
          <material>
            <pbr>
              <metal>
                <albedo>0.8 0.8 0.8 1</albedo>         <!-- light grey -->
                <roughness>0.3</roughness>              <!-- medium smoothness -->
                <metalness>0.9</metalness>              <!-- highly metallic -->
              </metal>
            </pbr>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.9 0.9 0.9 1</specular>
            <emissive>0 0 0 1</emissive>
          </material>
        </visual>
        <self_collide>true</self_collide>
        <gravity>true</gravity>
      </link>
      <joint name='left_wheel_joint_1' type='revolute'>
        <pose relative_to='base_link'>0.42 -0.32 -0.08500000000000001 0 0 0</pose>
        <parent>base_link</parent>
        <child>left_wheel_1_2</child>
        <axis>
          <xyz>1 0 0</xyz>
          <limit>
            <lower>-10000000000000000</lower>
            <upper>10000000000000000</upper>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference>
            <spring_stiffness>0</spring_stiffness>
          </dynamics>
        </axis>
      </joint>
      <link name='left_wheel_1_2'>
        <pose relative_to='left_wheel_joint_1'>0 0 0 0 0 0</pose>
        <inertial>
          <pose>-0.02499999999999997 4.662936703425657e-15 3.608224830031759e-16 0 0 0</pose>
          <mass>0.52089580936855184</mass>
          <inertia>
            <ixx>0.0016360000000000001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.00092500000000000004</iyy>
            <iyz>0</iyz>
            <izz>0.00092500000000000004</izz>
          </inertia>
        </inertial>
        <collision name='left_wheel_1_2_collision'>
          <pose>-0.42 0.32 0.08500000000000001 0 0 0</pose>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://r2_description/meshes/r2_chassis/left_wheel_1_2.stl</uri>
            </mesh>
          </geometry>
          <surface>
            <contact>
              <ode/>
            </contact>
            <friction>
              <ode>
                <mu>0.20000000000000001</mu>
                <mu2>0.20000000000000001</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name='left_wheel_1_2_visual'>
          <pose>-0.42 0.32 0.08500000000000001 0 0 0</pose>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://r2_description/meshes/r2_chassis/left_wheel_1_2.stl</uri>
            </mesh>
          </geometry>
          <material>
            <pbr>
              <metal>
                <albedo>0.02 0.02 0.02 1</albedo>      <!-- near black -->
                <roughness>0.9</roughness>              <!-- high roughness = matte -->
                <metalness>0.1</metalness>
              </metal>
            </pbr>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
            <emissive>0 0 0 1</emissive>
          </material>
        </visual>
        <self_collide>true</self_collide>
      </link>
      <joint name='right_wheel_joint_1' type='revolute'>
        <pose relative_to='base_link'>-0.42 -0.32 -0.08500000000000001 0 0 0</pose>
        <parent>base_link</parent>
        <child>left_wheel_2_1</child>
        <axis>
          <xyz>-1 0 0</xyz>
          <limit>
            <lower>-10000000000000000</lower>
            <upper>10000000000000000</upper>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference>
            <spring_stiffness>0</spring_stiffness>
          </dynamics>
        </axis>
      </joint>
      <link name='left_wheel_2_1'>
        <pose relative_to='right_wheel_joint_1'>0 0 0 0 0 0</pose>
        <inertial>
          <pose>0.02499999999999963 -2.775557561562891e-16 4.232725281383409e-15 0 0 0</pose>
          <mass>0.52089580936855151</mass>
          <inertia>
            <ixx>0.0016360000000000001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.00092500000000000004</iyy>
            <iyz>0</iyz>
            <izz>0.00092500000000000004</izz>
          </inertia>
        </inertial>
        <collision name='left_wheel_2_1_collision'>
          <pose>0.42 0.32 0.08500000000000001 0 0 0</pose>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://r2_description/meshes/r2_chassis/left_wheel_2_1.stl</uri>
            </mesh>
          </geometry>
          <surface>
            <contact>
              <ode/>
            </contact>
            <friction>
              <ode>
                <mu>0.20000000000000001</mu>
                <mu2>0.20000000000000001</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name='left_wheel_2_1_visual'>
          <pose>0.42 0.32 0.08500000000000001 0 0 0</pose>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://r2_description/meshes/r2_chassis/left_wheel_2_1.stl</uri>
            </mesh>
          </geometry>
          <material>
            <pbr>
              <metal>
                <albedo>0.02 0.02 0.02 1</albedo>      <!-- near black -->
                <roughness>0.9</roughness>              <!-- high roughness = matte -->
                <metalness>0.1</metalness>
              </metal>
            </pbr>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
            <emissive>0 0 0 1</emissive>
          </material>
        </visual>
        <self_collide>true</self_collide>
      </link>
      <joint name='left_wheel_joint_2' type='revolute'>
        <pose relative_to='base_link'>0.42 -0.32 -0.615 0 0 0</pose>
        <parent>base_link</parent>
        <child>left_wheel_1_1</child>
        <axis>
          <xyz>1 0 0</xyz>
          <limit>
            <lower>-10000000000000000</lower>
            <upper>10000000000000000</upper>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference>
            <spring_stiffness>0</spring_stiffness>
          </dynamics>
        </axis>
      </joint>
      <link name='left_wheel_1_1'>
        <pose relative_to='left_wheel_joint_2'>0 0 0 0 0 0</pose>
        <inertial>
          <pose>-0.02499999999999997 4.496403249731884e-15 4.440892098500626e-16 0 0 0</pose>
          <mass>0.52089580936855184</mass>
          <inertia>
            <ixx>0.0016360000000000001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.00092500000000000004</iyy>
            <iyz>0</iyz>
            <izz>0.00092500000000000004</izz>
          </inertia>
        </inertial>
        <collision name='left_wheel_1_1_collision'>
          <pose>-0.42 0.32 0.615 0 0 0</pose>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://r2_description/meshes/r2_chassis/left_wheel_1_1.stl</uri>
            </mesh>
          </geometry>
          <surface>
            <contact>
              <ode/>
            </contact>
            <friction>
              <ode>
                <mu>0.20000000000000001</mu>
                <mu2>0.20000000000000001</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name='left_wheel_1_1_visual'>
          <pose>-0.42 0.32 0.615 0 0 0</pose>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://r2_description/meshes/r2_chassis/left_wheel_1_1.stl</uri>
            </mesh>
          </geometry>
          <material>
            <pbr>
              <metal>
                <albedo>0.02 0.02 0.02 1</albedo>      <!-- near black -->
                <roughness>0.9</roughness>              <!-- high roughness = matte -->
                <metalness>0.1</metalness>
              </metal>
            </pbr>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
            <emissive>0 0 0 1</emissive>
          </material>
        </visual>
        <self_collide>true</self_collide>
      </link>
      <joint name='right_wheel_joint_2' type='revolute'>
        <pose relative_to='base_link'>-0.42 -0.32 -0.615 0 0 0</pose>
        <parent>base_link</parent>
        <child>left_wheel_1_3</child>
        <axis>
          <xyz>-1 0 0</xyz>
          <limit>
            <lower>-10000000000000000</lower>
            <upper>10000000000000000</upper>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference>
            <spring_stiffness>0</spring_stiffness>
          </dynamics>
        </axis>
      </joint>
      <link name='left_wheel_1_3'>
        <pose relative_to='right_wheel_joint_2'>0 0 0 0 0 0</pose>
        <inertial>
          <pose>0.02499999999999991 3.885780586188048e-16 -4.440892098500626e-15 0 0 0</pose>
          <mass>0.52089580936855184</mass>
          <inertia>
            <ixx>0.0016360000000000001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.00092500000000000004</iyy>
            <iyz>0</iyz>
            <izz>0.00092500000000000004</izz>
          </inertia>
        </inertial>
        <collision name='left_wheel_1_3_collision'>
          <pose>0.42 0.32 0.615 0 0 0</pose>
          <geometry>
            <mesh>
              <scale>0.001 0.001 0.001</scale>
              <uri>package://r2_description/meshes/r2_chassis/left_wheel_1_3.stl</uri>
            </mesh>
          </geometry>
          <surface>
