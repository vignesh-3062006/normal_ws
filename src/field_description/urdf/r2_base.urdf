<?xml version="1.0" ?>
<robot name="r2_base">

<link name="base_link">
  <inertial>
    <origin xyz="0.01358011215083441 0.005131451701245265 0.15090330982902161" rpy="0 0 0"/>
    <mass value="77.94379059774784"/>
    <inertia ixx="7.999801" iyy="3.281846" izz="10.135858" ixy="-0.026618" iyz="0.018519" ixz="-0.589569"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://field_description/meshes/r2_base_meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="black">
        <color rgba="0.05 0.05 0.05 1.0"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://field_description/meshes/r2_base_meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<!-- ZED camera mount -->
<link name="zed_camera_link" />

<joint name="base_camera_joint" type="fixed">
  <parent link="base_link"/>
  <child link="zed_camera_link"/>
  <origin xyz="0.2 0 0.28" rpy="0 0 0" />
</joint>
  
<!-- Camera Center -->
<link name="zed_camera_center">
    <visual>
      <origin xyz="-0.01 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://field_description/meshes/track_meshes/zed2i.stl"/>
      </geometry>
      <material name="black">
          <color rgba="0.05 0.05 0.05 1.0"/>
      </material>
    </visual>
</link>

<joint name="zed_camera_center_joint" type="fixed">
  <parent link="zed_camera_link"/>
  <child link="zed_camera_center"/>
  <origin xyz="0 0 0.015" rpy="0 0 0" />
</joint>


<!-- Left Camera -->
<link name="zed_left_camera_frame">
</link>

<joint name="zed_left_camera_joint" type="fixed">
  <parent link="zed_camera_center"/>
  <child link="zed_left_camera_frame"/>
  <origin xyz="-0.01 0.06 0" rpy="0 0 0" />
</joint>

<link name="zed_left_camera_frame_optical"/>
<joint name="zed_left_camera_optical_joint" type="fixed">
  <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  <parent link="zed_left_camera_frame"/>
  <child link="zed_left_camera_frame_optical"/>
</joint>

<!-- Right Camera -->
<link name="zed_right_camera_frame">
</link>

<joint name="zed_right_camera_joint" type="fixed">
  <parent link="zed_camera_center"/>
  <child link="zed_right_camera_frame"/>
  <origin xyz="-0.01 -0.06 0" rpy="0 0 0" />
</joint>

<link name="zed_right_camera_frame_optical"/>
<joint name="zed_right_camera_optical_joint" type="fixed">
  <origin xyz="0 0 0" rpy="-1.5708 0.0 -1.5708"/>
  <parent link="zed_right_camera_frame"/>
  <child link="zed_right_camera_frame_optical"/>
</joint>

<link name="laser"/>

<joint name="lidar_joint" type="fixed">
  <origin xyz="0.1 0 0" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="laser"/>
</joint>

</robot>