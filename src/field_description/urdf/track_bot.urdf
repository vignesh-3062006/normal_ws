            </geometry>
        </collision>
    </link>
    

    <link name="base_footprint"/>

    <joint name="base_link_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <joint name="driver_wheel_1_left_joint" type="continuous">
        <parent link="base_link"/>
        <child link="driver_wheel_1_left"/>
        <origin xyz="0.265194 0.334058 0.21" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="driven_wheel_2_left_joint" type="continuous">
        <parent link="base_link"/>
        <child link="driven_wheel_2_left"/>
        <origin xyz="0.135138 0.334058 0.07" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="driven_wheel_3_left_joint" type="continuous">
        <parent link="base_link"/>
        <child link="driven_wheel_3_left"/>
        <origin xyz="-0.034861 0.334058 0.04" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="drive_wheel_left_joint" type="continuous">
        <parent link="base_link"/>
        <child link="drive_wheel_left"/>
        <origin xyz="-0.214806 0.334058 0.069998" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="driven_wheel_1_right_joint" type="continuous">
        <parent link="base_link"/>
        <child link="driven_wheel_1_right"/>
        <origin xyz="0.265194 -0.287942 0.21" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="driven_wheel_2_right_joint" type="continuous">
        <parent link="base_link"/>
        <child link="driven_wheel_2_right"/>
        <origin xyz="0.135138 -0.288122 0.07" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="driven_wheel_3_right_joint" type="continuous">
        <parent link="base_link"/>
        <child link="driven_wheel_3_right"/>
        <origin xyz="-0.034861 -0.287813 0.04" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="drive_wheel_right_joint" type="continuous">
        <parent link="base_link"/>
        <child link="drive_wheel_right"/>
        <origin xyz="-0.214806 -0.28747 0.069997" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="track_left_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_left"/>
    </joint>

    <joint name="track_right_joint" type="fixed">
        <parent link="base_link"/>
        <child link="track_right"/>
    </joint>

    <gazebo>
        <plugin name="gz::sim::systems::DiffDrive" filename="gz-sim-diff-drive-system">

        <!-- Wheel Information -->
        <left_joint>drive_wheel_left_joint</left_joint>
        <right_joint>drive_wheel_right_joint</right_joint>
        <wheel_separation>0.46</wheel_separation>
        <wheel_diameter>0.05</wheel_diameter>


        <!-- Limits -->
        <max_wheel_torque>100</max_wheel_torque>
        <max_wheel_acceleration>50.0</max_wheel_acceleration>

        
        <!-- Output -->
        <topic>cmd_vel</topic>
        <odometry_frame_id>/model/my_robot/odometry</odometry_frame_id>
        <robot_base_frame_id>base_link</robot_base_frame_id>

        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>

        </plugin>
    </gazebo>


</robot>