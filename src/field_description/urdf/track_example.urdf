    <gazebo>
        <plugin filename="libignition-gazebo-diff-drive-system.so" name="ignition::gazebo::systems::DiffDrive">
        <robotnamespace></robotnamespace>
        <!-- Wheel Configuration -->
        <left_joint>dummy_left_joint_1</left_joint>
        <right_joint>dummy_right_joint_1</right_joint>
        <left_joint>dummy_left_joint_2</left_joint>
        <right_joint>dummy_right_joint_2</right_joint>
        <left_joint>dummy_left_joint_4</left_joint>
        <right_joint>dummy_right_joint_4</right_joint>
        <left_joint>dummy_left_joint_5</left_joint>
        <right_joint>dummy_right_joint_5</right_joint>
        <left_joint>dummy_left_joint_6</left_joint>
        <right_joint>dummy_right_joint_6</right_joint>
        <left_joint>dummy_left_joint_7</left_joint>
        <right_joint>dummy_right_joint_7</right_joint>
        <left_joint>dummy_left_joint_8</left_joint>
        <right_joint>dummy_right_joint_8</right_joint>
        <wheel_separation>0.7</wheel_separation>
        <wheel_radius>0.05</wheel_radius>

        <!-- Topic Configuration -->
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
        <tf_topic>/tf</tf_topic>
        <!-- CRITICAL: Frame IDs for TF Publishing -->
        <!-- ONLY use these two tags - remove all others -->
        <max_wheel_torque>2</max_wheel_torque>
        <max_wheel_acceleration>1.0</max_wheel_acceleration>

        <!-- Output -->
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <odom_publish_frequency>50</odom_publish_frequency>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>false</publish_wheel_tf>
        <publish_tf>true</publish_tf>
        </plugin>
    </gazebo>

    <gazebo reference="lidar_link_1">
        <sensor name="lidar_sensor" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <visualize>true</visualize>
        <always_on>true</always_on>
        <update_rate>2</update_rate>
        <topic>scan</topic>
        <lidar>
            <scan>
            <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-1.5708</min_angle>
                <max_angle>1.5708</max_angle>
            </horizontal>
            </scan>
            <range>
            <min>0.3</min>
            <max>12.0</max>
            </range>
        </lidar>
        <gz_frame_id>lidar_link_1</gz_frame_id>  <!-- CRITICAL -->
        </sensor>
    </gazebo>

    <gazebo reference="zed_link_1">
        <sensor name="rgbd_camera" type="rgbd_camera">
        <update_rate>15</update_rate>

        <camera>
            <horizontal_fov>1.87</horizontal_fov>
            <vertical_fov>1.19</vertical_fov>
            <image>
            <width>1280</width>
            <height>720</height>
            <format>R8G8B8</format>
            </image>
            <clip>
            <near>0.2</near>
            <far>10.0</far>
            </clip>
        </camera>

        <depth_camera>
            <clip>
            <near>0.1</near>
            <far>10.0</far>
            </clip>
        </depth_camera>

        <always_on>true</always_on>
        <visualize>true</visualize>

        <topic>camera</topic>

        <!-- 🔥 THIS IS THE FIX -->
        <gz_frame_id>zed_link_1</gz_frame_id>
        </sensor>
    </gazebo>

</robot>